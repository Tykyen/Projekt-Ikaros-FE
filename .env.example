# Base URL backendu (REST + WebSocket). V produkci POVINNÉ build-arg (jinak FE volá localhost).
# Mělo by být totožné s BE BACKEND_BASE_URL (veřejná BE URL).
VITE_API_URL=http://localhost:3000

# Cloudflare Turnstile SITE key (veřejný — patří do FE bundlu). Dev test key vždy projde.
# V produkci nastav reálný site-key z Cloudflare dashboardu.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Sentry/GlitchTip DSN pro error tracking (veřejný — patří do FE bundlu).
# Prázdné = monitoring vypnutý (no-op). V produkci nastav přes GitHub vars.
VITE_SENTRY_DSN=
