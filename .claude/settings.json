{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".claude/hooks/denik-reminder.ps1\"",
            "timeout": 10,
            "statusMessage": "Kontrola chyboveho deniku"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".claude/hooks/glossary-reminder.ps1\"",
            "timeout": 10,
            "statusMessage": "Kontrola slovnicku pojmu"
          }
        ]
      }
    ]
  }
}

