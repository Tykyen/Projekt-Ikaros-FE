# eslint@10 vs eslint-plugin-jsx-a11y@6.10.2 (peer deklaruje jen eslint ≤9) →
# npm ci by na tom peer konfliktu padlo. jsx-a11y funguje i s flat configem/novým
# eslintem, jen má zastaralý peer range. legacy-peer-deps = tolerovat peer konflikt
# (chování starého npm), NEmění verze ani lock. Workaround do upgrade jsx-a11y.
legacy-peer-deps=true
