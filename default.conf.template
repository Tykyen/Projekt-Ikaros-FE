# 14.3 — nginx config jako envsubst TEMPLATE (nginx:alpine zpracuje
# /etc/nginx/templates/*.template → /etc/nginx/conf.d/ při startu kontejneru).
# Nahrazované proměnné (NGINX_ENVSUBST_FILTER v Dockerfile chrání nginx $uri):
#   ${BACKEND_HOST}     — holý host backendu BEZ schématu (např. api.projekt-ikaros.com).
#                         V connect-src kryje https (REST/polling) i wss (Socket.IO) naráz.
#   ${CSP_HEADER_NAME}  — "Content-Security-Policy-Report-Only" (sběr) / "Content-Security-Policy" (enforce).
#   ${PRERENDER_HOST}   — host:port prerender sidecaru (15B.1), default prerender:3000.

# 15B.1 — prerender pro crawlery. Tyto map/upstream MUSÍ být v http kontextu;
# conf.d/*.conf je include-ováno uvnitř http {}, takže patří sem (před server).

# 1) je požadavek od crawlera? (User-Agent whitelist hlavních botů + sociálních scraperů)
map $http_user_agent $prerender_ua {
    default 0;
    "~*(googlebot|bingbot|seznambot|yandex|duckduckbot|baiduspider|applebot|facebookexternalhit|facebot|twitterbot|discordbot|slackbot|linkedinbot|whatsapp|telegrambot|pinterest|redditbot|embedly)" 1;
}

# 2) je to VEŘEJNÁ routa povolená k prerenderu? (whitelist = bezpečnostní hranice,
#    drží prerender mimo auth/citlivé cesty jako /reset-password, /admin, /chat)
map $uri $prerender_path {
    default 0;
    "~^/$"                                                 1;
    "~^/podminky/?$"                                       1;
    "~^/ikaros/(napoveda|novinky|vesmiry)/?$"              1;
    "~^/ikaros/(clanky|galerie)(/[^/]+)?/?$"               1;
    "~^/ikaros/systemy(/[^/]+)?/?$"                        1;
    "~^/svet/[^/]+/?$"                                     1;
}

# 3) prerender JEN když crawler AND veřejná routa (AND dvou map přes konkatenaci)
map "$prerender_ua:$prerender_path" $do_prerender {
    default 0;
    "1:1"   1;
}

# Upstream na sidecar (literal host po envsubst → žádný runtime resolver potřeba).
upstream prerender_backend {
    server ${PRERENDER_HOST};
}

server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

    # Hashované assety (mají hash v názvu = immutable) — cache na rok.
    # POZOR: `location =` (exact) má prioritu nad tímto regexem, takže
    # /sw.js a /index.html níže se sem nezahrnou.
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|webp|avif|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable" always;
        add_header X-Content-Type-Options "nosniff" always;
    }

    # Service worker — nikdy necachovat, jinak se nová verze SW nenačte.
    location = /sw.js {
        add_header Cache-Control "no-cache, must-revalidate" always;
        add_header X-Content-Type-Options "nosniff" always;
    }

    # 15B.2 — sitemap.xml musí být na FE originu (SEO same-host pravidlo), ale obsah
    # generuje backend dynamicky z DB. Proxy na public API host (globální prefix `api`).
    # Exact `=` match má prioritu před `location /` (prerender větví). robots.txt je
    # statický soubor v rootu → servíruje ho try_files níž (žádná location netřeba).
    # BACKEND_HOST dodá deploy (stejně jako pro CSP).
    location = /sitemap.xml {
        proxy_pass https://${BACKEND_HOST}/api/sitemap.xml;
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_HOST};
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 15s;
        add_header X-Content-Type-Options "nosniff" always;
    }

    # index.html + SPA fallback — vždy revalidovat (no-cache), aby po deployi
    # prohlížeč načetl nový vstupní bod s odkazy na nové hashované assety.
    # add_header se v location nedědí z parent serveru → security hlavičky
    # musí být zopakované zde.
    #
    # 14.3 — bezpečnostní hlavičky na HTML dokumentu (sem patří hlavní XSS-CSP).
    #   • CSP: whitelist zdrojů skriptů/stylů/spojení. 'sha256-…' = inline
    #     pre-hydration theme setter v index.html (statický → hash; CI guard
    #     scripts/check-csp-hash.mjs hlídá, že hash sedí se skriptem).
    #     Externí povolení: challenges.cloudflare.com (Turnstile), fonts.google*
    #     (fonty), res.cloudinary.com (obrázky+dice textury fetch), www.youtube.com
    #     + i.ytimg.com (YT IFrame API: zvuky světa + video embedy), ${BACKEND_HOST}.
    #     Ústupky doložené report-only fází (2026-06-19):
    #       'unsafe-inline' v style-src — knihovny (router ap.) injektují inline <style>.
    #       'unsafe-eval' v script-src — YouTube www-widgetapi volá eval (3rd party,
    #         CSP nemá per-doménový eval → musí být globální). Skripty jinak tvrdé.
    #   • HSTS: vynutí HTTPS (ctěno jen po HTTPS; preload zatím NE — nevratné).
    #   • X-XSS-Protection "0": legacy auditor je deprecated + děravý; CSP ho nahrazuje.
    location / {
        # 15B.1 — crawler na veřejné routě → interní přesměrování na prerender.
        # `if` obsahuje jen `rewrite ... last` (jedna z bezpečných operací uvnitř
        # if — viz „if is evil"); pro lidi i nepublic cesty padá flow níž na SPA.
        if ($do_prerender = 1) {
            rewrite ^ /__prerender last;
        }
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache, must-revalidate" always;
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-XSS-Protection "0" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        # 17.6 — camera/microphone/display-capture delegovány na meet.jit.si (Voice
        # krčma přes Jitsi iframe); bez toho rodič feature nedeleguje a A/V v iframe
        # se zablokuje i s allow atributem.
        add_header Permissions-Policy "geolocation=(), camera=(self \"https://meet.jit.si\"), microphone=(self \"https://meet.jit.si\"), display-capture=(self \"https://meet.jit.si\"), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()" always;
        add_header ${CSP_HEADER_NAME} "default-src 'self'; script-src 'self' 'sha256-aLzJ9M1HuC1LpYuRRSxecV5hSNtv9voRlyuEpOLPi28=' 'unsafe-eval' https://challenges.cloudflare.com https://www.youtube.com https://meet.jit.si; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://res.cloudinary.com https://${BACKEND_HOST} https://i.ytimg.com; connect-src 'self' data: ${BACKEND_HOST} https://res.cloudinary.com https://challenges.cloudflare.com https://meet.jit.si wss://meet.jit.si; frame-src https://challenges.cloudflare.com https://www.youtube.com https://www.youtube-nocookie.com https://meet.jit.si; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests" always;
    }

    # 15B.1 — interní cíl prerenderu (zvenčí nedostupný; jen rewrite z location /).
    # $request_uri = PŮVODNÍ cesta (rewrite ji nezmění) → sidecar dostane správnou URL.
    # Cookie/Authorization úmyslně mažeme — render musí běžet jako anonym (leak-safe,
    # spec §3). Bots stejně CSP neenforce-ují, proto sem CSP hlavičky nedáváme.
    location = /__prerender {
        internal;
        proxy_pass http://prerender_backend$request_uri;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie "";
        proxy_set_header Authorization "";
        proxy_read_timeout 30s;
        # Když sidecar selže/timeoutne, pusť bota radši na holou SPA než 5xx.
        proxy_intercept_errors on;
        error_page 500 502 503 504 = @spa_fallback;
    }

    # Záchranný SPA shell, když prerender nedojede (graceful degradation).
    location @spa_fallback {
        rewrite ^ /index.html break;
    }
}
